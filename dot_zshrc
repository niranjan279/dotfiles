# --- Environment Variables & Paths ---
export PATH="$HOME/.local/bin:/home/cdlen/.lmstudio/bin:$PATH"
export PATH="/usr/local/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export EDITOR="nvim"
export FZF_BASE=/usr/share/fzf

# --- Fast Completion Caching (Replaces heavy OMZ compinit) ---
autoload -Uz compinit
if [ $(date +%j) != $(stat -c %Y ~/.zcompdump 2>/dev/null | xargs -I {} date +%j -d @{}) ]; then
  compinit
else
  compinit -C
fi

# --- LAZY LOAD NVM (Speeds up startup drastically) ---
if [ -s "/usr/share/nvm/init-nvm.sh" ]; then
  lazy_nvm() {
    unset -f nvm node npm npx pnpm yarn
    source /usr/share/nvm/init-nvm.sh
    "$@"
  }
  nvm()  { lazy_nvm nvm "$@"; }
  node() { lazy_nvm node "$@"; }
  npm()  { lazy_nvm npm "$@"; }
  npx()  { lazy_nvm npx "$@"; }
  pnpm() { lazy_nvm pnpm "$@"; }
  yarn() { lazy_nvm yarn "$@"; }
fi

# --- History Settings ---
export HISTFILE="$HOME/.zsh_history"  # <--- ADD THIS LINE
export HISTCONTROL=ignoreboth
export HISTORY_IGNORE="(\&|[bf]g|c|clear|history|exit|q|pwd|* --help)"
export SAVEHIST=10000
export HISTSIZE=10000
setopt SHARE_HISTORY
# --- Fast Man Page Colors (Static strings instead of spawning 'tput' on startup) ---
export LESS_TERMCAP_md=$'\E[1;32m'
export LESS_TERMCAP_me=$'\E[0m'

# --- Aliases ---
alias ls="eza --icons"
alias cat="bat"
alias tree="eza --tree --icons --git-ignore"
alias grep="rg"
alias vim="nvim"
alias ecad="nvim scp://root@192.168.18.160//etc/caddy/Caddyfile"

# CachyOS / Arch specific aliases
alias make="make -j$(nproc)"
alias ninja="ninja -j$(nproc)"
alias n="ninja"
alias c="clear"
alias rmpkg="sudo pacman -Rsn"
alias cleanch="sudo pacman -Scc"
alias fixpacman="sudo rm /var/lib/pacman/db.lck"
alias update="sudo pacman -Syu"
alias please="sudo"
alias tb="nc termbin.com 9999"
alias cleanup="sudo pacman -Rsn \$(pacman -Qtdq)"
alias jctl="journalctl -p 3 -xb"
alias rip="expac --timefmt='%Y-%m-%d %T' '%l\t%n %v' | sort | tail -200 | nl"

bindkey -e

# --- Zsh Plugins (Order matters for ghost text!) ---

# 1. Syntax highlighting goes first
if [ -f "/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh  # Debian/Ubuntu path
elif [ -f "/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
    source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh  # Arch path
fi

# 2. History substring search next
if [ -f "/usr/share/zsh-history-substring-search/zsh-history-substring-search.zsh" ]; then
    source /usr/share/zsh-history-substring-search/zsh-history-substring-search.zsh
elif [ -f "/usr/share/zsh/plugins/zsh-history-substring-search/zsh-history-substring-search.zsh" ]; then
    source /usr/share/zsh/plugins/zsh-history-substring-search/zsh-history-substring-search.zsh
fi

# 3. Autosuggestions MUST go last so it can catch the others
if [ -f "/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh  # Debian/Ubuntu path
elif [ -f "/usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
    source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh  # Arch path
fi

# Force the plugin to fetch from your history strategy explicitly
export ZSH_AUTOSUGGEST_STRATEGY=(history)
# --- Restore FZF Keybindings & Completions ---
# FZF Key Bindings (Debian/Ubuntu fallback path included)
if [ -f "/usr/share/doc/fzf/examples/key-bindings.zsh" ]; then
    source /usr/share/doc/fzf/examples/key-bindings.zsh
elif [ -f "/usr/share/fzf/key-bindings.zsh" ]; then
    source /usr/share/fzf/key-bindings.zsh
fi

# FZF Completions (Debian/Ubuntu fallback path included)
if [ -f "/usr/share/doc/fzf/examples/completion.zsh" ]; then
    source /usr/share/doc/fzf/examples/completion.zsh
elif [ -f "/usr/share/fzf/completion.zsh" ]; then
    source /usr/share/fzf/completion.zsh
fi

# --- Command Line Tools Initialization ---
eval "$(zoxide init zsh)"
alias cd="z"

# --- Prompt (Starship goes LAST) ---
eval "$(starship init zsh)"
