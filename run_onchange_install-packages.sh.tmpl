#!/bin/bash

# Unified package list
PACKAGES=(
    zsh
    neovim
    git
    curl
)

{{ if eq .chezmoi.osRelease.id "arch" -}}
sudo pacman -Syu --needed --noconfirm "${PACKAGES[@]}"
{{ else if eq .chezmoi.osRelease.id "ubuntu" "debian" -}}
sudo apt-get update
sudo apt-get install -y "${PACKAGES[@]}"
{{ end -}}









